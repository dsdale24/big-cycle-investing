{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(git:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python scripts/*:*)",
      "Bash(python3 scripts/*:*)",
      "Bash(pip install:*)"
    ]
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/create_worktree_from_head.py"
          }
        ]
      }
    ]
  }
}
